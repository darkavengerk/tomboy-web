# Tomboy desktop source — reference only, not part of this repo
ref/

# Claude Code project memory (local settings only — skills are shared)
.claude/*
!.claude/skills/

graphify-out/cache/*

# Root-level node_modules (if any tool writes here; app/ has its own ignore)
node_modules/

# Git worktrees (created via `git worktree add .worktrees/<branch>`)
.worktrees/

# Generated by `npm run codegraph:sync` (app/scripts/sync-codegraph.mjs)
app/static/codegraph.json
app/static/codegraph-meta.json
app/static/codegraph-communities.json

# Pipeline (rM → Pi → desktop OCR → Tomboy) — see pipeline/README.md
pipeline/config/pipeline.yaml
pipeline/data/
pipeline/logs/
pipeline/state/
pipeline/.venv/
pipeline/__pycache__/

# OCR service (FastAPI GOT-OCR2 sidecar) — see ocr-service/
ocr-service/.venv/
ocr-service/**/__pycache__/
ocr-service/.pytest_cache/
ocr-service/src/*.egg-info/
