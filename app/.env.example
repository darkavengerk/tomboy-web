# Copy to `.env` and fill in.
# All PUBLIC_* vars are inlined into the client bundle by Vite — they're not secrets.
PUBLIC_DROPBOX_APP_KEY=

# Firebase: Web Push for the schedule-note feature.
# Console → Project settings → General → Your apps → Web app SDK config
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
# Project settings → Cloud Messaging → Web Push certificates → Key pair
PUBLIC_FIREBASE_VAPID_KEY=
