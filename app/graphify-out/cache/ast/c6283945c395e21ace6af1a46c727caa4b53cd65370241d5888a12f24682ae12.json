dence": "EXTRACTED", "source_file": "/var/home/umayloveme/workspace/tomboy-web/.worktrees/tigress/app/src/lib/editor/autoLink/titleProvider.ts", "source_location": "L122", "weight": 1.0}, {"source": "autolink_titleprovider_ensuretitleindexready", "target": "autolink_titleprovider_ensuresubscribed", "relation": "calls", "confidence": "EXTRACTED", "source_file": "/var/home/umayloveme/workspace/tomboy-web/.worktrees/tigress/app/src/lib/editor/autoLink/titleProvider.ts", "source_location": "L192", "weight": 1.0}, {"source": "autolink_titleprovider_ensuretitleindexready", "target": "autolink_titleprovider_dosharedrefresh", "relation": "calls", "confidence": "EXTRACTED", "source_file": "/var/home/umayloveme/workspace/tomboy-web/.worktrees/tigress/app/src/lib/editor/autoLink/titleProvider.ts", "source_location": "L194", "weight": 1.0}], "raw_calls": [{"caller_nid": "autolink_titleprovider_dosharedrefresh", "callee": "finally", "is_member_call": true, "source_file": "/var/home/umayloveme/workspace/tomboy-web/.worktrees/tigress/app/src/lib/editor/autoLink/titleProvider.ts", "source_location": "L52"}, {"caller_nid": "autolink_titleprovider_dosharedrefresh", "callee": "(async () => {\n\t\tconst notes = await listNotesShared();\n\t\tconst next: TitleEntry[] = [];\n\t\tfor (const n of notes) {\n\t\t\tif (!n || typeof n.title !== 'string') continue;\n\t\t\tconst trimmed = n.title.trim();\n\t\t\tif (!trimmed) continue;\n\t\t\tnext.push({\n\t\t\t\ttitle: trimmed,\n\t\t\t\tguid: n.guid\n\t\t\t});\n\t\t}\n\t\t// Build first-wins title\u2192guid map. `listNotes()` returns notes\n\t\t// sorted by changeDate DESC, so iterating first-wins gives\n\t\t// \"most-recently-changed wins\" semantics on any stray duplicate\n\t\t// title (the uniqueness invariant is enforced elsewhere but this\n\t\t// keeps lookups deterministic when it is violated).\n\t\tconst nextByTitle = new Map<string, string>();\n\t\tfor (const e of next) {\n\t\t\tif (!nextByTitle.has(e.title)) nextByTitle.set(e.title, e.guid);\n\t\t}\n\t\tsharedByTitle = nextByTitle;\n\n\t\t// Compute a {added, removed} delta before reassigning sharedEntries.\n\t\t// \"added\" = entries in next whose guid is absent from old, or whose\n\t\t//   title changed for the same guid (rename: new title is \"added\").\n\t\t// \"removed\" = entries in old whose guid is absent from next, or whose\n\t\t//   title changed (rename: old title is \"removed\").\n\t\t// This replaces the former `entriesEquivalent` boolean early-out:\n\t\t// when both arrays are empty the set is unchanged and we skip broadcast,\n\t\t// exactly preserving the previous \"no broadcast when nothing changed\"\n\t\t// guarantee (O(N * doc * titles) saved for body-only edits, toggleFavorite, \u2026).\n\t\tconst oldByGuid = new Map<string, TitleEntry>(sharedEntries.map((e) => [e.guid, e]));\n\t\tconst nextByGuid = new Map<string, TitleEntry>(next.map((e) => [e.guid, e]));\n\t\tconst added = next.filter((e) => {\n\t\t\tconst o = oldByGuid.get(e.guid);\n\t\t\treturn !o || o.title !== e.title;\n\t\t});\n\t\tconst removed = sharedEntries.filter((e) => {\n\t\t\tconst n = nextByGuid.get(e.guid);\n\t\t\treturn !n || n.title !== e.title;\n\t\t});\n\t\tsharedEntries = next;\n\t\tif (added.length === 0 && removed.length === 0) return;\n\t\tconst delta: TitleDelta = { added, removed };\n\t\tfor (const l of sharedListeners) l(delta);\n\t})", "is_member_call": false, "source_file": "/var/home/umayloveme/workspace/tomboy-web/.worktrees/tigress/app/src/lib/editor/autoLink/titleProvider.ts", "source_location": "L52"}, {"caller_nid": "autolink_titleprovider_ensuresubscribed", "callee": "onInvalidate", "is_member_call": false, "source_file": "/var/home/umayloveme/workspace/tomboy-web/.worktrees/tigress/app/src/lib/editor/autoLink/titleProvider.ts", "source_location": "L106"}, {"caller_nid": "autolink_titleprovider_createtitleprovider", "callee": "add", "is_member_call": true, "source_file": "/var/home/umayloveme/workspace/tomboy-web/.worktrees/tigress/app/src/li