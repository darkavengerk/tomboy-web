# Copy to bridge/.env (gitignored) and fill in.
# Used by `npm run deploy` (bridge/scripts/deploy.mjs) to SSH into the
# bridge host and rebuild + restart the Podman/Quadlet unit.

# Required: SSH target. Plain hostname, user@host, or a ~/.ssh/config alias.
BRIDGE_DEPLOY_HOST=user@bridge.example.com

# Optional. Defaults shown after the `=`.
#BRIDGE_DEPLOY_PORT=22
#BRIDGE_DEPLOY_KEY=~/.ssh/id_ed25519
#BRIDGE_DEPLOY_PATH=~/tomboy-web/bridge
#BRIDGE_DEPLOY_BRANCH=main
#BRIDGE_DEPLOY_IMAGE_TAG=term-bridge:latest
#BRIDGE_DEPLOY_CONTAINER_UNIT=term-bridge.container
#BRIDGE_DEPLOY_SERVICE=term-bridge.service

# Extra args spliced into the ssh invocation (space-separated). Example:
#BRIDGE_DEPLOY_SSH_ARGS=-o StrictHostKeyChecking=accept-new
