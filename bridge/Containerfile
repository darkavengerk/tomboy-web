FROM node:22-bookworm-slim AS build
# node-pty is a native addon — needs python + a C++ toolchain to build.
# These stay in the build image only; the runtime image below copies the
# compiled node_modules tree out, so the final image stays slim.
RUN apt-get update \
 && apt-get install -y --no-install-recommends python3 make g++ \
 && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY package.json tsconfig.json ./
RUN npm install --no-audit --no-fund
COPY src ./src
RUN npx tsc -p .
RUN npm prune --omit=dev

FROM node:22-bookworm-slim
RUN apt-get update \
 && apt-get install -y --no-install-recommends openssh-client ca-certificates \
 && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY package.json ./
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/dist ./dist
ENV NODE_ENV=production
ENV BRIDGE_PORT=3000
EXPOSE 3000
USER node
CMD ["node", "dist/server.js"]
