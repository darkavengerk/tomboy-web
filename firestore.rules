rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user namespace: device tokens and schedule items live under
    // users/{uid}/. Only the matching authenticated user can read or write.
    // The Cloud Function uses the Admin SDK and bypasses these rules.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
